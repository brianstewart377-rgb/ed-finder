{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/App.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/components/ui/**",
    "src/features/system-detail/simulation-preview/index.ts"
  ],
  "ignoreDependencies": ["vite-plugin-pwa", "@testing-library/jest-dom"],
  "rules": {
    "files": "error",
    "dependencies": "off",
    "devDependencies": "off",
    "unlisted": "off",
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "duplicates": "off"
  }
}
