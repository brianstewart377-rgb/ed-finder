{
  "name": "ed-finder",
  "private": true,
  "version": "0.1.2",
  "packageManager": "yarn@1.22.22",
  "type": "module",
  "description": "ED Finder frontend — Vite + React + TypeScript, served at /.",
  "scripts": {
    "dev:doctor": "node scripts/dev-doctor.mjs",
    "dev:doctor:strict": "node scripts/dev-doctor.mjs --strict",
    "prestart": "npm run dev:doctor",
    "predev": "npm run dev:doctor",
    "start": "node scripts/start-or-reuse.mjs",
    "dev": "vite",
    "bakeoff:dev": "vite --config vite.bakeoff.config.ts",
    "bakeoff:typecheck": "tsc --noEmit -p bakeoff/tsconfig.json",
    "bakeoff:lint": "eslint bakeoff vite.bakeoff.config.ts playwright.bakeoff.config.ts --max-warnings 0",
    "bakeoff:build": "vite build --config vite.bakeoff.config.ts",
    "bakeoff:e2e": "playwright test --config playwright.bakeoff.config.ts",
    "map-foundation:dev": "vite --config vite.map-foundation.config.ts",
    "map-foundation:typecheck": "tsc --noEmit -p map-foundation/tsconfig.json",
    "map-foundation:lint": "eslint map-foundation stage26e-route src/features/map-foundation vite.map-foundation.config.ts vite.authoritative-regions.ts playwright.map-foundation.config.ts playwright.map-foundation.matrix.config.ts playwright.map-foundation.visual.config.ts playwright.map-foundation.accessibility.config.ts playwright.stage26e-route.config.ts --max-warnings 0",
    "map-foundation:test": "node scripts/run-vitest.mjs run src/features/map-foundation",
    "map-foundation:build": "vite build --config vite.map-foundation.config.ts",
    "map-foundation:e2e": "playwright test --config playwright.map-foundation.config.ts",
    "map-foundation:matrix": "playwright test --config playwright.map-foundation.matrix.config.ts",
    "map-foundation:visual": "playwright test --config playwright.map-foundation.visual.config.ts",
    "map-foundation:accessibility": "playwright test --config playwright.map-foundation.accessibility.config.ts",
    "stage26e-route:build": "node scripts/stage26e-route-vite.mjs build --configLoader runner",
    "stage26e-route:preview": "node scripts/stage26e-route-vite.mjs preview",
    "stage26e-route:e2e": "playwright test --config playwright.stage26e-route.config.ts",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && vite build --configLoader runner",
    "build:typecheck": "tsc --noEmit && node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && vite build --configLoader runner",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 10",
    "test": "node scripts/run-vitest.mjs run",
    "test:operator": "node scripts/run-vitest.mjs run OperatorCockpitTab api.operator useHashRoute",
    "test:planner": "node scripts/run-vitest.mjs run src/features/colony-planner src/features/system-detail/simulation-preview",
    "test:map": "node scripts/run-vitest.mjs run src/features/map src/lib/api.map.test.ts",
    "test:stores": "node scripts/run-vitest.mjs run src/store src/hooks",
    "test:ci": "yarn test:operator && yarn test:planner && yarn test:map && yarn test:stores && node scripts/run-vitest.mjs run src/features/admin src/features/cluster-search src/features/expansion-plans src/features/fc-planner src/features/search-tuning src/features/system-detail/SystemDetailModal.test.tsx src/lib",
    "test:watch": "node scripts/run-vitest.mjs watch",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium",
    "types:gen": "node scripts/types-gen.mjs"
  },
  "dependencies": {
    "@deck.gl/core": "9.3.7",
    "@deck.gl/layers": "9.3.7",
    "@deck.gl/react": "9.3.7",
    "@deck.gl/widgets": "9.3.7",
    "@loaders.gl/core": "4.4.3",
    "@luma.gl/core": "9.3.6",
    "@luma.gl/engine": "9.3.6",
    "@luma.gl/shadertools": "9.3.6",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@radix-ui/react-visually-hidden": "^1.2.7",
    "@react-three/fiber": "9.6.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.6.0",
    "three": "0.185.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.17",
    "globals": "^15.14.0",
    "jsdom": "^25.0.0",
    "knip": "^6.27.0",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.3.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "workbox-build": "^7.3.0",
    "workbox-window": "^7.3.0"
  }
}
