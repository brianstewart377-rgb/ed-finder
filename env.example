# ── ED Finder environment variables ─────────────────────────────────────────
# Copy this file to `.env` and fill in the real values before running
# `sudo bash setup.sh` or `docker compose up -d`.

# Postgres password (used by postgres, pgbouncer, api, eddn, importer).
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=change-me

# Optional read-only Postgres DSN for admin/operator read surfaces and admin
# check operations. Leave blank to reuse DATABASE_URL with read-only
# transactions until a dedicated role is provisioned.
DATABASE_READONLY_URL=

# Admin-token — required for /api/admin/* and /api/cache/clear.
# Leave blank to disable those endpoints entirely (default / safest).
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Optional read-only station enrichment status artifact for the Admin tab.
# Generate it from an operator job with:
#   python3 scripts/station_enrichment_status.py --json > /data/logs/station-enrichment-status.json
# Leave blank to show enrichment status as unavailable.
ENRICHMENT_STATUS_JSON_PATH=

# Optional read-only warehouse reconciliation/status artifact for the Admin tab.
# Publish a sanitized/reviewed warehouse reconciliation JSON report to a path
# mounted into the API container, for example /data/logs/warehouse-status.json.
# Leave blank to show warehouse status as unavailable.
ENRICHMENT_WAREHOUSE_STATUS_JSON_PATH=

# Comma-separated list of allowed CORS origins.
# Change this for staging/dev deployments.
CORS_ORIGINS=https://ed-finder.app,https://www.ed-finder.app

# Set to "true" only when debugging locally. Leaks asyncpg error text
# (SQL, table/column names) in HTTP responses when true.
EXPOSE_ERROR_DETAIL=false

# Logging level for all Python services.
LOG_LEVEL=INFO

# Maintenance retention posture.
# Superseded/expired evidence rows keep the latest historical row per subject and
# prune older history after this many days during weekly maintenance.
EVIDENCE_RECORD_RETENTION_DAYS=90
# Completed/failed admin job rows older than this are pruned during weekly
# maintenance to keep the ops ledger bounded.
ADMIN_JOB_RUN_RETENTION_DAYS=60

# Targeted EDSM enrichment pacing. Keep these conservative for bulk station/body
# backfills; Retry-After from EDSM is honored before these 429 defaults.
EDSM_HTTP_REQUEST_DELAY_SECONDS=0.5
EDSM_HTTP_429_BACKOFF_SECONDS=60
EDSM_HTTP_429_BACKOFF_MULTIPLIER=2

# Grafana admin credentials (only used with --profile monitoring).
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me
