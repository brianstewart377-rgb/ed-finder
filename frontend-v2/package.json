{
  "name": "ed-finder-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ED Finder v2 \u2014 Vite + React + TypeScript (proof of concept). Mounts at /v2/ alongside the existing vanilla JS app at /.",
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 3000",
    "dev": "vite",
    "build": "vite build",
    "build:typecheck": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:gen": "openapi-typescript ${VITE_OPENAPI_URL:-https://ed-finder.app/openapi.json} -o src/types/api.gen.ts"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.7.2",
    "vite": "^6.3.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "workbox-build": "^7.3.0",
    "workbox-window": "^7.3.0"
  }
}
