{
  "name": "ed-finder-v2",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "description": "ED Finder v2 — Vite + React + TypeScript (proof of concept). Mounts at /v2/ alongside the existing vanilla JS app at /.",
  "scripts": {
    "dev:doctor": "node scripts/dev-doctor.mjs",
    "dev:doctor:strict": "node scripts/dev-doctor.mjs --strict",
    "prestart": "npm run dev:doctor",
    "predev": "npm run dev:doctor",
    "start": "node scripts/start-or-reuse.mjs",
    "dev": "vite",
    "build": "vite build --configLoader runner",
    "build:typecheck": "tsc --noEmit && vite build --configLoader runner",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 10",
    "test": "node scripts/run-vitest.mjs run",
    "test:operator": "node scripts/run-vitest.mjs run OperatorCockpitTab api.operator useHashRoute",
    "test:planner": "node scripts/run-vitest.mjs run src/features/colony-planner src/features/system-detail/simulation-preview",
    "test:map": "node scripts/run-vitest.mjs run src/features/map src/lib/api.map.test.ts",
    "test:stores": "node scripts/run-vitest.mjs run src/store src/hooks",
    "test:ci": "yarn test:operator && yarn test:planner && yarn test:map && yarn test:stores && node scripts/run-vitest.mjs run src/features/admin src/features/search-tuning src/features/system-detail/SystemDetailModal.test.tsx src/lib",
    "test:watch": "node scripts/run-vitest.mjs watch",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium",
    "types:gen": "node scripts/types-gen.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "lucide-react": "^0.469.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^2.15.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.17",
    "globals": "^15.14.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.3.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "workbox-build": "^7.3.0",
    "workbox-window": "^7.3.0"
  }
}
