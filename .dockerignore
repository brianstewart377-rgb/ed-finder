# ── ED:Finder — Root .dockerignore ────────────────────────────────────────────
# Build context is the repo root so Docker sends the whole repo.
# Exclude large/unnecessary files to keep build context fast.

# Python bytecode
**/__pycache__/
**/*.pyc
**/*.pyo

# Data files (large — never bake into image)
data/
*.db
*.db-shm
*.db-wal
*.json.gz
*.gz

# Git
.git/
.gitignore

# Docs / scripts (not needed in image)
*.md
*.sh
*.txt
SCP_COMMANDS.txt
DEPLOY_COMMANDS.txt
ONE_COMMAND_DEPLOY.txt

# Editor
*.swp
*.swo
.DS_Store
.env
.env.*

# Node (if any)
node_modules/
